# EduMind backend configuration. Everything is optional in dev:
# no DATABASE_URL -> in-memory store, no ANTHROPIC_API_KEY -> MOCK_LLM mode.

# --- server ---------------------------------------------------------------
HOST=0.0.0.0            # bind to all interfaces so phones on the LAN can reach it
PORT=8080
# CORS_ORIGINS=https://yourapp.example.com,https://other.example.com   # default: permissive (dev)

# --- database (Postgres 16) -----------------------------------------------
# Neon: pooled URL for DATABASE_URL, direct URL for migrations.
# DATABASE_URL=postgresql://user:pass@host/db?pgbouncer=true
# DIRECT_URL=postgresql://user:pass@host/db
# Local (docker-compose up -d):
# DATABASE_URL=postgresql://edumind:edumind@localhost:5432/edumind
# DIRECT_URL=postgresql://edumind:edumind@localhost:5432/edumind

# --- LLM ---------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...          # moderation (omni-moderation-latest); skipped with a warning if unset
MOCK_LLM=false                   # true: serve golden specs with simulated latency (no keys needed)
MOCK_LATENCY_MS=4000
PROMPT_CACHE_TTL=1h              # 1h (2x write cost) or 5m (1.25x) — 1h pays off with steady traffic
MODEL_DEFAULT=claude-haiku-4-5
MODEL_ESCALATION=claude-sonnet-4-6
ESCALATE_ARABIC=false            # set true if your Haiku Arabic-quality measurements say so
MAX_GENERATIONS_PER_HOUR=20

# --- images (Tier 2, flagged) ----------------------------------------------
# IMAGE_PROVIDER_API_KEY=...
# IMAGE_PROVIDER_URL=https://api.your-flux-provider.com/v1/generate
# Tier 3 (full AI background sets) is design-only in v1 — see DECISIONS.md.
