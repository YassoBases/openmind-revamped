// EduMind backend — Prisma 6 + Postgres 16.
// Neon users: DATABASE_URL = pooled URL (?pgbouncer=true), DIRECT_URL = direct
// connection for migrations (auto-suspend during long calls bit us in v3).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Student {
  id                  String    @id @default(cuid())
  name                String // nickname only — never a real-name field (minors)
  gender              String? // 'm' | 'f' — Arabic grammar ONLY
  grade               Int
  language            String    @default("en")
  color               String    @default("#58CC02")
  interest            String? // elementary game archetype (primary stage)
  learningContext     String? // middle-school context lens — legacy, fallback only
  interests           String[]  @default([]) // onboarding interests (1-2, both stages) — primary AI-flavor signal
  dailyGoal           Int       @default(3)
  xp                  Int       @default(0)
  streakCount         Int       @default(0)
  streakLastPlayedAt  DateTime?
  tokenHash           String    @unique
  // Client-generated, persisted per device install — the idempotency key for
  // POST /students. Nullable: older rows (and any caller that doesn't send
  // one) never populate it, and Postgres unique indexes allow any number of
  // NULLs. A retry with a matching id reissues a token for the SAME row
  // instead of creating a duplicate account (see routes/students.ts).
  installationId      String?   @unique
  createdAt           DateTime  @default(now())
  games               Game[]
  worlds              World[]
  xpEvents            XpEvent[]
  streakEvents        StreakEvent[]
  playSessions        PlaySession[]
  tutorMessages       TutorMessage[]
  learnProgress       LearnProgress[]
  learnEvidence       LearnEvidence[]
  placementTests      PlacementTestSession[]
}

// Middle-school learning progress (grades 7-9) — a separate domain from
// Game/PlaySession so game history and learning journeys never mix.
model LearnProgress {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  pathId       String
  experienceId String
  completedAt  DateTime @default(now())

  @@unique([studentId, pathId, experienceId])
  @@index([studentId, completedAt])
}

// One learner submission — the append-only evidence log behind per-skill
// readiness and error-pattern diagnostics. `id` is client-generated (not a
// cuid) so the log is idempotent across the local cap, batch upsert, and sync.
// A separate domain from LearnProgress: evidence never overwrites completion.
model LearnEvidence {
  id             String   @id
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  skillId        String
  representation String
  context        String?
  source         String // learn_step | checkpoint | tutor_block | tool_verify
  kind           String // exploration | prediction | construction | transfer | recall | explanation
  outcome        String // correct | partially_correct | incorrect | explored
  verification   String // server_verified | client_reported
  attempt        Int      @default(1)
  hints          Int      @default(0)
  recovered      Boolean  @default(false)
  errorPattern   String?
  toolId         String?
  pathId         String?
  experienceId   String?
  stepIndex      Int?
  ms             Int?
  createdAt      DateTime @default(now())

  @@index([studentId, skillId, createdAt])
}

model Game {
  id           String    @id @default(cuid())
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])
  gameType     String
  theme        String
  subject      String
  topic        String
  language     String
  status       String    @default("generating") // generating | ready | failed
  error        String?
  spec         Json? // the GameSpec — NEVER assembled HTML
  shellVersion String    @default("")
  thumbnailUrl String?
  bestScore    Int       @default(0)
  playCount    Int       @default(0)
  lastPlayedAt DateTime?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime? // soft delete
  playSessions PlaySession[]

  @@index([studentId, deletedAt, lastPlayedAt])
}

// A Lesson World: one lesson/topic → a planned sequence of short stages.
// The plan is one JSON blob; each stage's spec lives on its own row so
// stages generate, retry and prefetch independently.
model World {
  id        String    @id @default(cuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id])
  lessonId  String?
  subject   String
  topic     String
  language  String
  grade     Int
  status    String    @default("planning") // planning | ready | failed
  error     String?
  title     String?
  plan      Json? // WorldPlanContent
  createdAt DateTime  @default(now())
  deletedAt DateTime? // soft delete
  stages    WorldStage[]

  @@index([studentId, deletedAt, createdAt])
}

model WorldStage {
  worldId      String
  world        World     @relation(fields: [worldId], references: [id])
  index        Int // 1-based position in the plan
  status       String    @default("planned") // planned | generating | ready | failed
  error        String?
  spec         Json? // the assembled stage GameSpec (scope='stage')
  stars        Int?
  bestAccuracy Float?
  completedAt  DateTime?
  generatedAt  DateTime?

  @@id([worldId, index])
}

model PlaySession {
  id        String   @id @default(cuid())
  gameId    String? // null for Review-mode sessions (no backing game row)
  game      Game?    @relation(fields: [gameId], references: [id])
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  summary   Json // reportSummary payload (per-item results — feeds Review mode)
  xp        Int      @default(0)
  accuracy  Float    @default(0)
  createdAt DateTime @default(now())

  @@index([studentId, createdAt])
}

model TutorMessage {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  conversationId String
  role           String // 'student' | 'tutor'
  content        String
  responseType   String? // tutor turns: structured responseType
  context        Json? // learning context attached to the turn
  createdAt      DateTime @default(now())

  @@index([studentId, conversationId, createdAt])
}

model XpEvent {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([studentId, createdAt])
}

model StreakEvent {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  day       DateTime
  createdAt DateTime @default(now())

  @@unique([studentId, day])
}

model SpecCache {
  key       String   @id // sha256(subject|topic|language|gameType|theme|grade|difficulty|sessionLength)
  content   Json // de-personalized GameSpec content
  createdAt DateTime @default(now())
  expiresAt DateTime
}


model Grade {
  id        String    @id @default(cuid())
  name      String    // e.g. "Grade 1", "First Grade"
  index     Int       @unique // 1..6 — matches Student.grade
  subjects  Subject[]
  createdAt DateTime  @default(now())
}

model Subject {
  id            String        @id @default(cuid())
  title         String
  content       String
  orderIndex    Int
  gradeId       String
  grade         Grade         @relation(fields: [gradeId], references: [id])
  learningPaths LearningPath[]
  createdAt     DateTime      @default(now())

  @@index([gradeId, orderIndex])
}

model LearningPath {
  id          String     @id @default(cuid())
  name        String
  description String
  subjectId   String
  subject     Subject    @relation(fields: [subjectId], references: [id])
  pathNodes   PathNode[]
  questions   Question[]
  createdAt   DateTime   @default(now())

  @@index([subjectId])
}

model PathNode {
  id              String       @id @default(cuid())
  title           String
  subject         String // free-text subject label on this node
  topic           String
  orderIndex      Int
  xpReward        Int
  depth           Int          @default(0) // spiral depth: 0=basic, 1=deepen, 2=mastery
  learningPathId  String
  learningPath    LearningPath @relation(fields: [learningPathId], references: [id])
  createdAt       DateTime     @default(now())

  @@index([learningPathId, orderIndex])
}

// Placement tests: adaptive difficulty pre-test at the start of each learning
// path. Each learning path has its own question bank. The test adapts: a correct
// answer escalates the difficulty, a wrong answer de-escalates it. After ~10
// questions the student is placed at the right PathNode to continue learning.
// Themes (جسر / طريق / خريطة = bridge / road / map) are cosmetic — the frontend
// renders the progress track accordingly.
// ─────────────────────────────────────────────────────────────────────────────

model Question {
  id              String       @id @default(cuid())
  learningPathId  String
  learningPath    LearningPath @relation(fields: [learningPathId], references: [id])
  type            String // choice | drag_drop | spin | connect
  difficulty      String // easy | medium | hard
  content         Json // type-specific payload (see Zod QuestionContent)
  linkedNodeId    String? // optional: the PathNode this question tests (for precise placement)
  createdAt       DateTime     @default(now())

  @@index([learningPathId, difficulty])
}

model PlacementTestSession {
  id                String    @id @default(cuid())
  studentId         String
  student           Student   @relation(fields: [studentId], references: [id])
  learningPathId    String
  theme             String    // bridge | road | map
  status            String    @default("in_progress") // in_progress | completed | abandoned
  answers           Json      @default("[]") // [{ questionId, type, difficulty, correct, response, answeredAt }]
  currentDifficulty String    @default("medium")
  questionCount     Int       @default(0)
  placedNodeId      String? // set when status = completed
  startedAt         DateTime  @default(now())
  completedAt       DateTime?

  @@index([studentId, learningPathId])
}
